---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const entries = await getCollection('projects', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const archiveNote = entry.data.archived
  ? `From the archive — written in ${entry.data.date.getFullYear()}, during my M.S. at Clemson. Kept as-is for posterity.`
  : undefined;
---

<EntryLayout
  title={entry.data.title}
  excerpt={entry.data.excerpt}
  date={entry.data.date}
  heroImage={entry.data.heroImage}
  heroAlt={entry.data.heroAlt}
  heroCaption={entry.data.heroCaption}
  backLabel="Projects"
  backHref="/projects/"
  archiveNote={archiveNote}
  ogImage={entry.data.heroImage ?? entry.data.image}
>
  <Content />
</EntryLayout>
