---
import { getCollection } from 'astro:content';
import ArchiveLayout from '../../layouts/ArchiveLayout.astro';

const entries = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const items = entries.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  image: entry.data.image,
  date: entry.data.date,
  archived: entry.data.archived,
}));
---

<ArchiveLayout
  title="Projects"
  description="Things I build in my spare time — current side projects up front, grad-school work (2017–2018) kept as an archive below."
  basePath="/projects"
  items={items}
/>
